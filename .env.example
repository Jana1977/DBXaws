# Copy this file to `.env` (in the same directory) and fill in your real values.
# NEVER commit the real `.env` file - it is already excluded via .gitignore.
#
# Usage:
#   cp .env.example .env
#   (edit .env with your real values)
#   source .env
#   terraform init
#   terraform plan
#   terraform apply

# --- Databricks account-level service principal ---
# Create this in the Databricks Account Console:
# https://accounts.cloud.databricks.com -> User management -> Service principals -> Add service principal
# Then grant it the "Account Admin" role (select the SP -> Roles -> Account Admin).
# Generate an OAuth secret for it: select the SP -> Secrets -> Generate secret.
export TF_VAR_databricks_account_client_id="<your-service-principal-application-id>"
export TF_VAR_databricks_account_client_secret="<your-service-principal-client-secret>"

# Your Databricks Account ID (top-right corner of the Account Console)
export TF_VAR_databricks_account_id="<your-databricks-account-id>"

# --- AWS credentials ---
# Static IAM user access keys. Recommended: use a dedicated IAM user with
# least-privilege permissions needed to create VPC/S3/IAM resources.
export AWS_ACCESS_KEY_ID="<your-aws-access-key-id>"
export AWS_SECRET_ACCESS_KEY="<your-aws-secret-access-key>"
# export AWS_SESSION_TOKEN="<only-if-using-temporary-credentials>"

# AWS region to deploy into (must match terraform.tfvars "region")
export AWS_DEFAULT_REGION="us-east-1"
